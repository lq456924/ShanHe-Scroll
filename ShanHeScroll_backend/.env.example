# ============================================================
# MyTravel 环境变量模板
#
# 使用方式：
#   IDE（推荐）: 在 Run Configuration 中设置这些环境变量
#   命令行    : 复制为 .env 文件，启动前 source .env（Linux）或手动设置
#
# ⚠️ .env 文件已在 .gitignore 中，不会被提交到 Git
# ============================================================

# 数据库密码
DB_PASSWORD=your_db_password

# JWT 密钥（建议至少 256 位随机字符串）
# 生成方式: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here

# 邮箱配置（QQ 邮箱 SMTP）
MAIL_USERNAME=your_qq_email@qq.com
MAIL_PASSWORD=your_smtp_authorization_code
